max-history=5
sort=+time

on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action

width=400
height=100

outer-margin=0
margin=6
padding=10

border-size=1
border-radius=18

icons=1
max-icon-size=34
icon-location=left

markup=1
actions=1
history=1

font=JetBrainsMono Nerd Font 10
format= <b>%s</b>\n%b
text-alignment=left
default-timeout=3000
ignore-timeout=0
max-visible=8

layer=overlay
anchor=top-right

background-color=#1e1e2e80
text-color=#cdd6f4
border-color=#cba6f7b3
progress-color=over #313244

[urgency=high]
border-color=#fab387
