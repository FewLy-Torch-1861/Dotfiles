include=~/.config/mako/colors

max-history=10
sort=-time

on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action
on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/message.oga

font=Noto Sans Thai 12
width=400
height=100
outer-margin=10
margin=5
padding=5
border-size=1
border-radius=20
icons=1
max-icon-size=56
icon-location=left
# markup=1
actions=1
format= <b>%s</b>\n%b
text-alignment=center
default-timeout=10000
ignore-timeout=0
max-visible=8
layer=overlay
anchor=top-right

[urgency=high]
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category

[mode=do-not-disturb]
invisible=1

[mode=do-not-disturb app-name=status-notif]
invisible=0

[app-name=status-notif]
layer=overlay
history=0
anchor=top-center
