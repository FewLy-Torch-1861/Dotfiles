#!/bin/bash

# Hide cursor
tput civis

clear

# Get terminal size
rows=$(tput lines)
cols=$(tput cols)

msg="WELCOME BACK"

# Calulate centered pos
msg_len=${#msg}
row_pos=$((rows / 2))
col_pos=$(((cols - msg_len) / 2))

# Move cursor and print message
tput cup $row_pos $col_pos
tput bold
# echo -e "\e[1;97m$msg\e[0m"
echo -e "$msg"
tput sgr0

# Wait then exit
sleep 10
exit 0 
